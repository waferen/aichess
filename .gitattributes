# 自动处理换行符
* text=auto

# Shell脚本必须使用LF
*.sh text eol=lf
*.bash text eol=lf

# Python脚本使用LF
*.py text eol=lf

# 配置文件使用LF
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.txt text eol=lf
*.md text eol=lf

# Windows批处理文件使用CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
